APP_NAME=AI-Powered Student Intelligence System
API_V1_PREFIX=/api/v1
DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
# Use letters, digits, underscores only (required for safe auto CREATE DATABASE)
DB_NAME=student_intelligence

SECRET_KEY=replace-with-strong-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

ML_SERVICE_URL=http://localhost:8001

# Frontend dev servers (comma-separated). Add more if you use another host/port.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
# CORS_ALLOW_ALL=true
